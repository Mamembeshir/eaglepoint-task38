# MeritForge Environment Configuration
# Copy this file to .env and customize values for your deployment

# PostgreSQL Configuration
POSTGRES_USER=meritforge
POSTGRES_PASSWORD=meritforge_dev_password
POSTGRES_DB=meritforge
POSTGRES_PORT=5432

# Redis Configuration
REDIS_PORT=6379

# Application Security
SECRET_KEY=meritforge_dev_secret_key_change_in_production_32chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Configuration (comma-separated origins)
CORS_ORIGINS=https://localhost,https://127.0.0.1,http://localhost:3000,http://127.0.0.1:3000

# Application Settings
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Rate Limiting
RATE_LIMIT_PER_MINUTE=120

# Audit Log Retention (days)
AUDIT_LOG_RETENTION_DAYS=365

# Encryption Key Rotation (days)
ENCRYPTION_KEY_ROTATION_DAYS=180

# Frontend Configuration
VITE_API_URL=http://localhost:8000/api/v1
VITE_APP_NAME=MeritForge

# Port Mappings
HTTP_PORT=80
HTTPS_PORT=443
BACKEND_PORT=8000
FRONTEND_PORT=3000
