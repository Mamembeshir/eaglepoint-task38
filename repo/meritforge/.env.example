# PostgreSQL Configuration
POSTGRES_USER=meritforge
POSTGRES_PASSWORD=meritforge_secret
POSTGRES_DB=meritforge
POSTGRES_PORT=5432

# Redis Configuration
REDIS_PORT=6379

# Backend Configuration
BACKEND_PORT=8000
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_PEPPER_CURRENT=
PASSWORD_PEPPER_PREVIOUS=
REFRESH_TOKEN_HASH_KEYS=key-2026-01:replace-with-64-char-secret
REFRESH_TOKEN_HASH_ACTIVE_KEY_ID=key-2026-01
REFRESH_TOKEN_HASH_ROTATION_DAYS=180
SECURE_COOKIES=true
ACCESS_COOKIE_NAME=access_token
REFRESH_COOKIE_NAME=refresh_token
STEP_UP_HEADER_NAME=X-Step-Up-Password
USER_RATE_LIMIT_PER_MINUTE=120
INTEGRATION_HMAC_KEYS=integration-key-2026-01:replace-with-strong-secret
INTEGRATION_HMAC_TIMESTAMP_HEADER=X-MeritForge-Timestamp
INTEGRATION_HMAC_SIGNATURE_HEADER=X-MeritForge-Signature
INTEGRATION_HMAC_KEY_ID_HEADER=X-MeritForge-Key-Id
INTEGRATION_HMAC_CLOCK_SKEW_SECONDS=300

# Celery Configuration
CELERY_BEAT_INTERVAL_SECONDS=60

# Frontend Configuration
FRONTEND_PORT=3000
# Docker behind nginx (same-origin): leave empty so frontend calls /api/v1/... directly
VITE_API_URL=
VITE_APP_NAME=MeritForge
VITE_HTTPS=false
VITE_HTTPS_KEY_PATH=/certs/key.pem
VITE_HTTPS_CERT_PATH=/certs/cert.pem

# Nginx Configuration
HTTP_PORT=80
HTTPS_PORT=443

# Environment
NODE_ENV=development
DEBUG=false
CORS_ORIGINS=https://localhost,http://localhost:3000,http://localhost
# Development-only shared password used by backend/scripts/seed_dev_users.py
SEED_DEV_PASSWORD=MeritForgeDev!2026
